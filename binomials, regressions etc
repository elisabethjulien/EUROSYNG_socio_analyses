#989 to 876 rows

# Outliers in Y? In this case, more than outliers, it's a matter of checking there aren't errors in the dataset. 
boxplot(particip_total_df$particip_total, ylab = "Will to engage?")
dotchart(particip_total_df$particip_total, ylab = "Order of the data", xlab = "Will to engage?")
# No errors

#############
# Modelling #
#############

#transforming categorical data into factors for GLMs
particip_total_df$location <- as.factor(particip_total_df$location)
particip_total_df$job_other <- as.factor(particip_total_df$job_other)

# fit binomial model to run step and select model predictors

glm_bin <- glm(
  cbind(particip_total,27-particip_total) ~ memberngo + age + gender + 
    coast + mpa_prox + edu + location + hobbies_glm + work_ocean_group + job_other,
  family = binomial,
  data = na.omit(particip_total_df)
)

step(glm_bin)
#Refit final model as quasibinomial

glm1 <- glm(
  cbind(particip_total, 27 - particip_total) ~  memberngo + edu + location + hobbies_glm + work_ocean_group + job_other,
  family = quasibinomial,
  data = na.omit(particip_total_df)
)
nobs(glm1) # N = 876

# Model selection
summary(glm1)
drop1(glm1, test="Chisq")
#drop ngo membership
#Single term deletions
glm2 <- glm(
  cbind(particip_total, 27 - particip_total) ~  edu + location + hobbies_glm + work_ocean_group + job_other,
  family = quasibinomial,
  data = na.omit(particip_total_df)
)
Anova(glm2)
